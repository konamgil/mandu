{
  "name": "@mandujs/ate",
  "version": "0.19.2",
  "description": "Mandu ATE (Automation Test Engine) - extract/generate/run/report/heal/impact in one package",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./extractor": "./src/extractor.ts",
    "./ir": "./src/ir.ts",
    "./scenario": "./src/scenario.ts",
    "./codegen": "./src/codegen.ts",
    "./runner": "./src/runner.ts",
    "./oracle": "./src/oracle.ts",
    "./report": "./src/report.ts",
    "./heal": "./src/heal.ts",
    "./trace-parser": "./src/trace-parser.ts",
    "./impact": "./src/impact.ts",
    "./fs": "./src/fs.ts",
    "./types": "./src/types.ts",
    "./smart-select": "./src/smart-select.ts",
    "./coverage-gap": "./src/coverage-gap.ts",
    "./precommit": "./src/precommit.ts",
    "./prompts": "./src/prompts/index.ts",
    "./e2e-codegen": "./src/e2e-codegen.ts",
    "./e2e-runner": "./src/e2e-runner.ts",
    "./coverage-merger": "./src/coverage-merger.ts"
  },
  "files": [
    "src/**/*"
  ],
  "keywords": [
    "mandu",
    "ate",
    "automation",
    "e2e",
    "playwright",
    "ts-morph"
  ],
  "author": "konamgil",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konamgil/mandu.git",
    "directory": "packages/ate"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fast-glob": "catalog:",
    "ts-morph": "^26.0.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0",
    "playwright": ">=1.40.0"
  },
  "engines": {
    "bun": ">=1.3.12"
  }
}
