{
  "name": "@mandujs/playground-runner",
  "version": "8.0.0",
  "private": true,
  "description": "Phase 16.2 live Bun runtime on Cloudflare Sandboxes. Worker + Durable Object + adapter for running user-submitted Mandu code in isolated sandboxes with SSE streaming.",
  "type": "module",
  "sideEffects": false,
  "main": "./src/worker.ts",
  "types": "./src/types.ts",
  "exports": {
    ".": "./src/worker.ts",
    "./adapter": "./src/adapter.ts",
    "./docker-adapter": "./src/docker-adapter.ts",
    "./durable-object": "./src/durable-object.ts",
    "./security": "./src/security.ts",
    "./types": "./src/types.ts"
  },
  "files": [
    "src/**/*",
    "deploy/**/*",
    "Dockerfile",
    "Dockerfile.sandbox",
    "wrangler.toml.template",
    "README.md"
  ],
  "keywords": [
    "mandu",
    "playground",
    "cloudflare",
    "sandbox",
    "durable-object",
    "bun",
    "sse"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konamgil/mandu.git",
    "directory": "packages/playground-runner"
  },
  "author": "konamgil",
  "license": "MPL-2.0",
  "engines": {
    "bun": ">=1.3.12"
  },
  "peerDependencies": {
    "@mandujs/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/sandbox": "^0.1.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "wrangler": ">=3.0.0"
  },
  "scripts": {
    "test": "bun test tests",
    "dev": "bun run src/local-server.ts"
  }
}
