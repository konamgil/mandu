    "ssr_ttfb_p95_ms": {
      "unit": "ms",
      "direction": "lower-is-better",
      "description": "SSR response time from request start to first byte for the primary page route."
    },
    "hydration_p95_ms": {
      "unit": "ms",
      "direction": "lower-is-better",
      "description": "Time until all Mandu islands are hydrated on the client."
    },
    "initial_js_bundle_kb": {
      "unit": "kb",
      "direction": "lower-is-better",
      "description": "Transferred JavaScript payload needed for the first screen."
    },
    "hmr_latency_p95_ms": {
      "unit": "ms",
      "direction": "lower-is-better",
      "description": "Time from a source edit to browser-visible hot update in dev mode."
    },
    "route_scan_p95_ms": {
      "unit": "ms",
      "direction": "lower-is-better",
      "description": "Route discovery and manifest generation latency for the active project."
    },
    "resource_generation_p95_ms": {
      "unit": "ms",
      "direction": "lower-is-better",
      "description": "Resource generation latency for representative CRUD/resource workloads."
    }
  },
