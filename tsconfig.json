{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@mandujs/core": ["./packages/core/src/index.ts"],
      "@mandujs/core/*": ["./packages/core/src/*"],
      "@mandujs/cli": ["./packages/cli/src/main.ts"],
      "@mandujs/cli/*": ["./packages/cli/src/*"],
      "@mandujs/mcp": ["./packages/mcp/src/index.ts"],
      "@mandujs/mcp/*": ["./packages/mcp/src/*"],
      "@mandujs/ate": ["./packages/ate/src/index.ts"],
      "@mandujs/ate/prompts": ["./packages/ate/src/prompts/index.ts"],
      "@mandujs/ate/*": ["./packages/ate/src/*"],
      "@mandujs/edge": ["./packages/edge/src/index.ts"],
      "@mandujs/edge/*": ["./packages/edge/src/*"],
      "@mandujs/edge/workers": ["./packages/edge/src/workers/index.ts"],
      "@mandujs/edge/deno": ["./packages/edge/src/deno/index.ts"],
      "@mandujs/edge/vercel": ["./packages/edge/src/vercel/index.ts"],
      "@mandujs/edge/netlify": ["./packages/edge/src/netlify/index.ts"],
      "@mandujs/skills": ["./packages/skills/src/index.ts"],
      "@mandujs/skills/generator": ["./packages/skills/src/generator/index.ts"],
      "@mandujs/skills/loop-closure": ["./packages/skills/src/loop-closure/index.ts"],
      "@mandujs/skills/loop-closure/detectors": ["./packages/skills/src/loop-closure/detectors.ts"],
      "@mandujs/skills/*": ["./packages/skills/src/*.ts", "./packages/skills/*"],
      "@mandujs/playground-runner": ["./packages/playground-runner/src/worker.ts"],
      "@mandujs/playground-runner/adapter": ["./packages/playground-runner/src/adapter.ts"],
      "@mandujs/playground-runner/durable-object": ["./packages/playground-runner/src/durable-object.ts"],
      "@mandujs/playground-runner/security": ["./packages/playground-runner/src/security.ts"],
      "@mandujs/playground-runner/types": ["./packages/playground-runner/src/types.ts"]
    },
    "strict": true,
    "noUncheckedSideEffectImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["bun-types"]
  },
  "exclude": ["node_modules", "dist", "DNA", "demo"]
}
